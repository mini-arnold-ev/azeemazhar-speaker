---
import Base from "~/layouts/Base.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import ChampionKit from "~/components/ChampionKit.astro";

const base = import.meta.env.BASE_URL;
---

<Base
  title="Executive Education & Programmes — Azeem Azhar"
  description="Multi-session AI programmes for business schools, corporate L&D, and organisations that need depth over time."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-28 pb-16">
      <div class="container-prose">
        <p class="label mb-6">Engagement Format</p>
        <p class="text-body text-muted leading-relaxed max-w-2xl">
          Multi-session. For organisations and institutions that need depth over a single engagement. Azeem works alongside your team or faculty to deliver a structured programme across days, weeks, or months.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-10">
          <div>
            <p class="label mb-1">Duration</p>
            <p class="text-body">Custom</p>
          </div>
          <div>
            <p class="label mb-1">Audience</p>
            <p class="text-body">8–200 people</p>
          </div>
          <div>
            <p class="label mb-1">Format</p>
            <p class="text-body">Multi-session</p>
          </div>
          <div>
            <p class="label mb-1">Output</p>
            <p class="text-body">Cumulative insight</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Programme Formats -->
    <section class="section border-t border-border">
      <div class="container-prose">
        <p class="label mb-8">Programme Formats</p>
        <div class="space-y-10">
          <div>
            <h3 class="text-subhead font-light mb-3">Guest Faculty (2 Sessions)</h3>
            <p class="text-body text-muted">
              Azeem joins an existing executive education programme as a guest expert. Two sessions — typically a keynote or briefing followed by an interactive workshop — provide participants with both the macro view and practical application.
            </p>
            <p class="text-caption text-muted mt-2">↳ Business school exec ed, corporate university programmes</p>
            <p class="text-caption text-muted mt-2"><strong>Learning outcomes:</strong> Shared framework for evaluating AI decisions · First-hand experience with frontier AI tools · Sector-specific competitive analysis</p>
          </div>
          <div>
            <h3 class="text-subhead font-light mb-3">Half-Day AI Immersion</h3>
            <p class="text-body text-muted">
              A concentrated programme combining briefing, live AI demonstration, and strategic working session. Teams leave with genuine first-hand intuition about AI capabilities — not a second-hand account.
            </p>
            <p class="text-caption text-muted mt-2">↳ Board strategy days, leadership offsites, PE portfolio company days</p>
          </div>
          <div>
            <h3 class="text-subhead font-light mb-3">Multi-Week Strategic Programme</h3>
            <p class="text-body text-muted">
              Three to five sessions over weeks or months, building cumulative insight within your organisation. Each session advances the strategic conversation — from landscape orientation to sector-specific analysis to decision-making frameworks.
            </p>
            <p class="text-caption text-muted mt-2">↳ Corporate transformation programmes, board education series, PE portfolio development</p>
            <p class="text-caption text-muted mt-2"><strong>Learning outcomes:</strong> AI-literate leadership team · Prioritised action list for AI adoption · Governance framework for AI decisions · Sector-specific competitive positioning</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="section border-t border-border">
      <div class="container-prose">
        <p class="label mb-8">How It Works</p>
        <div class="space-y-8">
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">01</span>
            <div>
              <p class="text-subhead font-light mb-2">Scoping call</p>
              <p class="text-body text-muted">Initial conversation with your programme lead to understand learning objectives, audience profile, and how Azeem's sessions fit within the broader programme.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">02</span>
            <div>
              <p class="text-subhead font-light mb-2">Co-design</p>
              <p class="text-body text-muted">Session structure and content tailored to your specific context. For exec ed programmes, this includes alignment with other faculty and case materials.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">03</span>
            <div>
              <p class="text-subhead font-light mb-2">Delivery</p>
              <p class="text-body text-muted">Sessions delivered on your schedule. Each builds on the previous, creating a coherent arc from orientation to action.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">04</span>
            <div>
              <p class="text-subhead font-light mb-2">Post-programme synthesis</p>
              <p class="text-body text-muted">A written synthesis of the strategic themes and questions that emerged — a document your leadership team can use as a foundation for next steps.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Best Suited For -->
    <section class="section border-t border-border">
      <div class="container-prose">
        <p class="label mb-8">Best Suited For</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <p class="text-subhead font-light mb-2">Business School Executive Education</p>
            <p class="text-caption text-muted">Harvard Business School · London Business School · MIT Sloan · Oxford Saïd · INSEAD · Cambridge Judge</p>
          </div>
          <div>
            <p class="text-subhead font-light mb-2">Corporate Learning &amp; Development</p>
            <p class="text-caption text-muted">Fortune 500 leadership programmes · Corporate universities · AI transformation academies</p>
          </div>
          <div>
            <p class="text-subhead font-light mb-2">Board Education Series</p>
            <p class="text-caption text-muted">Quarterly board briefings · Non-exec director development · Governance committee deep dives</p>
          </div>
          <div>
            <p class="text-subhead font-light mb-2">Portfolio Company Programmes</p>
            <p class="text-caption text-muted">PE portfolio AI readiness · VC founder cohorts · Multi-company executive cohorts</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Formats -->
    <section class="section border-t border-border">
      <div class="container-prose">
        <p class="label mb-4">Other Formats</p>
        <p class="text-body text-muted mb-6">
          Looking for a single session instead? Explore <a href={`${base}/keynote/`} class="underline hover:text-[#f1f5f9] transition-colors">Keynote</a>, <a href={`${base}/fireside/`} class="underline hover:text-[#f1f5f9] transition-colors">Fireside Chat</a>, or <a href={`${base}/workshop/`} class="underline hover:text-[#f1f5f9] transition-colors">Workshop</a>.
        </p>
      </div>
    </section>

    <!-- Champion Kit -->
    <section class="section-tight border-t border-border">
      <div class="container-prose">
        <ChampionKit />
      </div>
    </section>

    <!-- CTA -->
    <section class="section border-t border-border">
      <div class="container-prose text-center">
        <h2 class="text-headline font-light mb-4">Discuss a programme</h2>
        <p class="text-body text-muted mb-8">Programme enquiries typically begin 3–6 months before delivery. Start with a scoping conversation.</p>
        <a href={`${base}/contact/`} class="btn-primary">Check availability</a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
