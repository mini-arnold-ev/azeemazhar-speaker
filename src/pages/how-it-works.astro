---
import Base from "~/layouts/Base.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import ChampionKit from "~/components/ChampionKit.astro";

const base = import.meta.env.BASE_URL;

const formats = [
  {
    name: "Keynote",
    slug: "keynote",
    duration: "45–60 min",
    audience: "100–5,000 attendees",
    description: "High-impact session with a provocative thesis, evidence, and strategic implications. For conferences, plenaries, and large leadership events.",
  },
  {
    name: "Fireside Chat",
    slug: "fireside",
    duration: "45–90 min",
    audience: "8–100 people",
    description: "Moderated conversation where the room drives the questions. Ideal for boards, CEO roundtables, investor gatherings, and executive offsites.",
  },
  {
    name: "Workshop",
    slug: "workshop",
    duration: "2–3 hours",
    audience: "8–50 people",
    description: "Briefing + live AI demonstration + strategic working session. Teams leave with frameworks and genuine first-hand experience.",
  },
  {
    name: "Programme",
    slug: "programme",
    duration: "Multi-session",
    audience: "8–200 people",
    description: "Extended engagement over weeks or months for executive education, corporate L&D, and organisations that need cumulative depth.",
  },
];

const rightFitYes = [
  "Conference keynotes (100–5,000 people)",
  "Board and C-suite sessions (8–30 people)",
  "Corporate leadership events and town halls",
  "Executive education programmes",
  "Investor and LP events",
  "Hybrid and virtual delivery",
];

const rightFitNo = [
  "Technical ML/AI engineering audiences",
  "Multi-speaker panels with less than 10 minutes per speaker",
];

const sectors = [
  { name: "Finance & Investment", clients: "Goldman Sachs, JP Morgan, Morgan Stanley, UBS, Baillie Gifford, CVC, Khosla Ventures" },
  { name: "Technology", clients: "Google, Microsoft, Meta, Spotify, Salesforce, Oracle, Deutsche Telekom" },
  { name: "Enterprise", clients: "BMW, Coca-Cola, P&G, Renault, IKEA, LEGO" },
  { name: "Advisory", clients: "McKinsey, BCG, Deloitte, EY, PwC, Accenture" },
  { name: "Academia", clients: "Harvard Business School, MIT, Oxford, Cambridge, London Business School, INSEAD" },
];
---

<Base
  title="How It Works — Azeem Azhar"
  description="How to work with Azeem Azhar: formats, process, and what to expect from a keynote, fireside, workshop, or programme."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20">
      <div class="container-prose">
        <p class="label mb-6">Working with Azeem</p>
        <h1 class="text-display font-light mb-6">Choose your format.</h1>
        <p class="text-subhead text-muted font-light">
          Every engagement starts with a conversation. Here's what's available.
        </p>
      </div>
    </section>

    <!-- Format Cards -->
    <section class="section border-t border-border">
      <div class="container-page">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          {formats.map((format) => (
            <a href={`${base}/${format.slug}/`} class="block group border border-border rounded-lg p-8 hover:border-[#475569] transition-colors">
              <p class="text-headline font-light mb-2 group-hover:text-white transition-colors">{format.name}</p>
              <div class="flex gap-4 mb-4">
                <span class="text-caption text-muted">{format.duration}</span>
                <span class="text-caption text-muted">·</span>
                <span class="text-caption text-muted">{format.audience}</span>
              </div>
              <p class="text-body text-muted">{format.description}</p>
              <p class="text-caption mt-4 text-[#94a3b8] group-hover:text-[#f1f5f9] transition-colors">Learn more →</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="section border-t border-border">
      <div class="container-prose">
        <p class="label mb-8">The Process</p>
        <div class="space-y-8">
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">01</span>
            <div>
              <p class="text-subhead font-light mb-2">Initial conversation</p>
              <p class="text-body text-muted">30-minute call to understand your audience, strategic questions, and what you want the room thinking about after.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">02</span>
            <div>
              <p class="text-subhead font-light mb-2">Custom framing</p>
              <p class="text-body text-muted">Azeem develops a tailored angle shaped by your industry, audience, and the decisions your leadership team is weighing.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">03</span>
            <div>
              <p class="text-subhead font-light mb-2">The session</p>
              <p class="text-body text-muted">Substantive, tailored, no filler. Format depends on your needs — keynote, fireside, workshop, or programme.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-caption text-muted font-mono shrink-0 mt-1">04</span>
            <div>
              <p class="text-subhead font-light mb-2">Post-session briefing</p>
              <p class="text-body text-muted">A concise note with core frameworks and questions to stress-test your strategy. Designed for your next executive meeting.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Right Fit -->
    <section class="section border-t border-border">
      <div class="container-prose">
        <p class="label mb-4">Is this the right fit?</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-8">
          <div>
            <p class="text-small font-medium mb-6">Azeem works with</p>
            <div class="space-y-3">
              {rightFitYes.map((item) => (
                <div class="flex items-start gap-3">
                  <span class="text-body mt-0.5 flex-shrink-0 text-green-400">✓</span>
                  <p class="text-body text-ink">{item}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-small font-medium text-muted mb-6">Probably not the best fit for</p>
            <div class="space-y-3">
              {rightFitNo.map((item) => (
                <div class="flex items-start gap-3">
                  <span class="text-body mt-0.5 flex-shrink-0 text-muted">✗</span>
                  <p class="text-body text-muted">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Client Logos -->
    <section class="section border-t border-border">
      <div class="container-page">
        <p class="label text-center mb-8">Select clients across sectors</p>
        <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-6">
          {sectors.map((sector) => (
            <div>
              <p class="text-small font-medium mb-1">{sector.name}</p>
              <p class="text-caption text-muted leading-relaxed">{sector.clients}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Champion Kit -->
    <section class="section-tight border-t border-border">
      <div class="container-prose">
        <ChampionKit />
      </div>
    </section>

    <!-- CTA -->
    <section class="section border-t border-border">
      <div class="container-prose text-center">
        <p class="text-headline font-light mb-4">~25 engagements per year</p>
        <p class="text-body text-muted mb-8">Early conversations are encouraged.</p>
        <a href={`${base}/contact/`} class="btn-primary">Check Availability</a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
